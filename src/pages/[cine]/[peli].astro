---
import MainLayout from '@/layouts/main.astro';
import { Bookmark, Clock } from '@lucide/astro';
import DatePicker from '@/components/DatePicker.astro';
import type { Movie } from '@/lib/types';
import { parseDate, normalizeDate, formatDuration } from '@/lib/utils';

// Obtener el parámetro de la URL
const { cine, peli } = Astro.params;

// Guard clause: Ignore requests for static assets (e.g., favicon.svg)
if (peli?.includes('.')) {
  return new Response(null, { status: 404 });
}

let date = new Date();
date.setDate(date.getDate() + 1);

// This fetch now runs on the server at request time
let moviesResponse = await fetch(`${Astro.url.origin}/api/peliculas/${cine}.json`);
if (!moviesResponse.ok) {
  // Handle error, perhaps return a 404 or throw
  throw new Error(`Error al obtener las películas para ${cine}`);
}
let allMoviesForCine = await moviesResponse.json();
const movie = allMoviesForCine?.find((m: Movie) => m.id === peli);

// ... (rest of the code)
if (!movie) {
  // Return a 404 response
  // For example: return Astro.redirect('/404'); or throw new Error("Película no encontrada");
  throw new Error(`Película no encontrada: ${peli} en ${cine}`);
}

// Check if movie is upcoming
const releaseDateObj = parseDate(movie.releaseDate);
const today = normalizeDate(new Date());
const isUpcoming = normalizeDate(releaseDateObj) > today;

// getStaticPaths has been removed to enable SSR.
---

<MainLayout content={{ title: movie.title }}>
  <section class="container mx-auto text-white overflow-hidden">
    <div class="relative py-4">
        <!-- Fondo blur con la imagen -->
        <div
        class="absolute inset-0 -z-10 mx-auto mt-14 mb-8 w-8/12 h-auto bg-cover bg-center"
        style={`background-image: url('${movie.img_primary}'); background-size: cover; background-position: center; filter: blur(16px); brightness(0.5);`}
        aria-hidden="true"
        ></div>
        <!-- Overlay oscuro para mejorar contraste -->
        <div class="absolute inset-0 bg-background/50 -z-10"></div>

        <h1 class="text-2xl md:text-4xl font-bold mb-4 capitalize" transition:name={`title-${movie.id}`}>{movie.title}</h1> <!-- Changed movie.id to movie.title for better display -->
        <!-- Póster y botón trailer -->
      <div class="flex flex-col md:flex-row md:justify-around md:items-start gap-4 md:gap-14">
        <div class="pl-1">
            <img src={movie.img_primary} alt={movie.title} class="rounded-lg shadow-lg w-full max-w-xs md:max-w-none md:w-96 mb-4" transition:name={`poster-${movie.id}`} />
            <div class="flex flex-wrap items-center gap-2 mb-4 pl-2">
                <span class="bg-yellow-100 text-yellow-800 text-xs font-medium me-2 px-2.5 py-0.5 rounded-full dark:bg-amber-900 dark:text-yellow-300">{movie.genre}</span>
                <span class="bg-yellow-100 text-yellow-800 text-xs font-medium me-2 px-2.5 py-0.5 rounded-full dark:bg-amber-900 dark:text-yellow-300">{movie.classification}</span>
                <span class="bg-yellow-100 text-yellow-800 text-xs font-medium me-2 px-2.5 py-0.5 rounded-full dark:bg-amber-900 dark:text-yellow-300">{movie.type}</span>
            </div>
            <div class="mb-4 mt-4 flex flex-col gap-4 pl-1">
                {isUpcoming && (
                  <div class="flex flex-col pl-4 border-l-4 border-yellow-300 rounded">
                      <span class="text-sm uppercase tracking-wider">Proximamente</span>
                      <span class="text-sm"> Estreno {movie.releaseDate}</span>
                  </div>
                )}
                <button class="flex items-center bg-yellow-400 hover:bg-yellow-500 text-black font-bold py-2 px-4 rounded-3xl justify-center cursor-pointer">
                    <Bookmark class="h-5 w-5 mr-2" />
                    <span>Añadir a Favoritos</span>
                </button>
            </div>
        </div>
        <div id="youtube-player" class="w-full aspect-video mx-auto rounded-lg overflow-hidden bg-black">
          {/* YouTube player will be inserted here by the client-side script */}
        </div>
        {/* <div id="youtube-player"></div> */}
      </div>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-[1fr_auto] w-full gap-10">
        <div class="">
          <p class="py-4 border-b border-gray-700 text-pretty">{movie.synopsis}</p>
          {!isUpcoming && (
            <div class="py-4 border-b border-gray-700 w-full">
              <span class="font-bold">Estreno </span>
              <span class="ml-2 text-blue-400 cursor-pointer">{movie.releaseDate}</span>
            </div>
          )}
          <div class="py-4 border-b border-gray-700 w-full">
            <span class="font-bold">Director</span>
            <span class="ml-2 text-blue-400 cursor-pointer">{movie.director}</span>
          </div>
          <div class="py-4 border-b border-gray-700 w-full">
            <span class="font-bold">Reparto</span>
            <span class="ml-2">
              {movie.actors.split(',').map((actor: any) => (
                <span class="text-blue-400 cursor-pointer">{actor.trim()}</span>
              )).reduce((prev:any, curr:any) => [prev, <span class="text-gray-400 mx-1">·</span>, curr])}
            </span>
          </div>
          <div class="py-4">
            <span class="font-bold">Duración</span>
            <span class="ml-2 text-yellow-400">{formatDuration(movie.duration)}</span>
          </div>
          
        </div>
        <div class="mt-4">
              <DatePicker initialDate={new Date()} />
              <div class="mt-4" id="showtimes-container">
                {movie.showtimes?.length > 0 ? (
                  movie.showtimes.map((showtime:any) => (
                    <div
                      class="flex items-center justify-start gap-4 p-2 border-b border-gray-600"
                    >
                      <span class="text-sm font-medium flex items-center">
                        <Clock class="h-5 w-5 mr-2" />
                        {showtime.hour}
                        </span>
                      <span class="text-sm text-blue-400">
                        {showtime.format}
                        </span>
                        <span class="bg-blue-400/10 text-blue-800 border border-blue-900 text-xs font-medium me-2 px-2.5 py-0.5 rounded-full">
                          {showtime.subtitled ? "Subtitulada" : "Doblada"}
                        </span>
                    </div>
                  ))
                ) : (
                  <div class="text-sm text-gray-400">No hay funciones disponibles.</div>
                )}
              </div>
        </div>
    </div>
  </section>
</MainLayout>

<script define:vars={{ trailerUrl: movie.trailer }}>
  // The library is already loaded globally in MainLayout
  const player = document.createElement('lite-youtube');

  // Extract video ID from various YouTube URL formats (watch, youtu.be, embed)
  const videoId = trailerUrl.match(/(?:https?:\/\/)?(?:www\.)?(?:youtube\.com\/(?:[^\/]+\/)?embed\/|youtube\.com\/watch\?v=|youtu\.be\/)([^& \n\r?]+)/)?.[1];

  if (videoId) {
    player.setAttribute('videoid', videoId);
    player.setAttribute('autoplay', 'false');
    player.setAttribute('autopause', 'true');
    player.setAttribute('posterquality', 'maxresdefault');
    player.classList.add('w-full', 'h-auto', 'mx-auto', 'rounded-lg', 'overflow-hidden');

    const container = document.getElementById('youtube-player');
    if (container) {
      container.innerHTML = ''; // Clear any existing content
      container.appendChild(player);
    }
  } else {
    console.error("Could not extract YouTube video ID from URL:", trailerUrl);
    const container = document.getElementById('youtube-player');
    if (container) {
      container.innerHTML = '<p class="text-center text-gray-400 p-4">Trailer no disponible</p>';
    }
  }
</script>

<script define:vars={{ cine, peliId: movie.id }}>
  // Listen for date changes from the DatePicker
  document.addEventListener('dateChange', async (event) => {
    const newDate = event.detail.date;
    const dateStr = newDate.toISOString().split('T')[0];

    try {
      const response = await fetch(`/api/peliculas/${cine}.json?date=${dateStr}`);
      if (!response.ok) {
        console.error("Error fetching movies for new date");
        return;
      }

      const updatedMovies = await response.json();
      const updatedMovie = updatedMovies?.find((m) => m.id === peliId);

      if (!updatedMovie) {
        console.error("Movie not found in response");
        return;
      }

      const showtimesContainer = document.getElementById('showtimes-container');
      if (!showtimesContainer) return;

      // Re-render showtimes
      if (updatedMovie.showtimes && updatedMovie.showtimes.length > 0) {
        showtimesContainer.innerHTML = updatedMovie.showtimes.map((showtime) => `
          <div class="flex items-center justify-start gap-4 p-2 border-b border-gray-600">
            <span class="text-sm font-medium flex items-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5 mr-2">
                <circle cx="12" cy="12" r="10"></circle>
                <polyline points="12 6 12 12 16 14"></polyline>
              </svg>
              ${showtime.hour}
            </span>
            <span class="text-sm text-blue-400">${showtime.format}</span>
            <span class="bg-blue-400/10 text-blue-800 border border-blue-900 text-xs font-medium me-2 px-2.5 py-0.5 rounded-full">
              ${showtime.subtitled ? "Subtitulada" : "Doblada"}
            </span>
          </div>
        `).join('');
      } else {
        showtimesContainer.innerHTML = '<div class="text-sm text-gray-400">No hay funciones disponibles.</div>';
      }
    } catch (error) {
      console.error("Error updating showtimes:", error);
    }
  });
</script>

