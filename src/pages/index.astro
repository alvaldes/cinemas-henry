<h1></h1>

<script>
import { defaultCines } from "@/lib/constants";

  if (typeof window !== 'undefined') {
    const storedCine = localStorage.getItem('selectedCine');
    let selectedCine = null;
    
    try {
      if (storedCine) {
        selectedCine = JSON.parse(storedCine);
      }
    } catch (e) {
      console.error("Error parsing selectedCine from localStorage:", e);
    }

    if (selectedCine && selectedCine.value) {
      window.location.href = `/${selectedCine.value}`;
    } else {
      const huajuapan = defaultCines.find(c => c.value === 'huajuapan') || defaultCines[0];
      window.location.href = `/${huajuapan.value}`;
    }
  }
</script>