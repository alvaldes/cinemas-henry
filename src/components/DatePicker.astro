---
interface Props {
  initialDate: Date;
}

const { initialDate } = Astro.props;
let selectedDate: string = initialDate.toLocaleDateString('en-CA');
let error: string | null = null;

// Get yesterday's date in YYYY-MM-DD format
const today = new Date();
const formattedToday = today.toLocaleDateString('en-CA');
---
<form class="space-y-4" autocomplete="off">
  <input
    type="date"
    id="dob"
    name="dob"
    value={selectedDate}
    min={formattedToday}
    class="mt-1 px-4 py-2 block mx-auto w-10/12 max-w-dvw md:w-40 rounded-md border border-gray-700 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 md:text-sm"
  />
  {error && <p class="text-red-500 text-sm mt-1">{error}</p>}
</form>

<script>
  const dateInput = document.getElementById('dob');

  if (dateInput) {
    // Reset to today on every page load — browser often preserves previous value
    // (refreshes, back/forward cache, View Transitions)
    const today = new Date().toLocaleDateString('en-CA');
    dateInput.value = today;

    // Use both 'change' and 'input' for broader browser compatibility
    function onDateChange() {
      const selectedDate = dateInput.value;
      const dateChangeEvent = new CustomEvent('dateChange', {
        detail: { date: new Date(selectedDate) },
        bubbles: true,
        composed: true,
      });
      document.dispatchEvent(dateChangeEvent);
    }

    dateInput.addEventListener('change', onDateChange);
    dateInput.addEventListener('input', onDateChange);
  } else {
    console.error("The element with id 'dob' was not found.");
  }
</script>
