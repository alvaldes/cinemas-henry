---
import { Menu, X, Bookmark, Clock, Search } from '@lucide/astro';
import NavDropdown from '@/components/NavDropdown.tsx';
import { defaultCines } from '@/lib/constants';

const pathCine = Astro.url.pathname.split('/')[1] ?? '';
const searchCine = defaultCines.some((c) => c.value === pathCine)
  ? pathCine
  : Astro.cookies.get('selectedCine')?.value ?? 'huajuapan';
const searchQuery = Astro.url.searchParams.get('q') ?? '';
---
<nav class="w-full bg-gray-900/50 text-white px-4">
  <div class="container mx-auto flex items-center justify-between py-4">
  {/* Logo */}
    <a href="/" class="flex items-center">
      <img src="/images/LogoH.webp" alt="Logo" class="h-8 w-auto max-w-none shrink-0 mr-4" />
    </a>

  {/* Search Input (desktop) */}
  <div class="hidden md:block flex-1 mx-4">
    <div class="relative" data-search-wrapper>
      <form class="flex border border-gray-700 rounded-lg overflow-hidden relative z-30" role="search" action={`/${searchCine}/buscar`} method="GET" data-search-form>
        <input
          type="text"
          name="q"
          value={searchQuery}
          placeholder="Buscar películas..."
          class="flex-1 px-4 py-2 bg-gray-800 text-white focus:outline-none"
          aria-label="Search movies"
          data-search-input
          autocomplete="off"
        />
        {searchQuery && (
          <button
            type="button"
            data-clear-search
            class="bg-gray-800 hover:bg-gray-700 text-gray-400 px-3 flex items-center border-r border-gray-700"
            aria-label="Limpiar búsqueda"
          >
            <X class="h-4 w-4" />
          </button>
        )}
        <button
          type="submit"
          class="bg-gray-800 hover:bg-gray-700 text-gray-500 px-4 py-2 flex items-center justify-center"
          aria-label="Buscar"
        >
          <Search class="h-5 w-5" />
        </button>
      </form>
      <ul
        data-search-suggestions
        class="hidden absolute top-0 left-0 right-0 z-20 bg-gray-800 rounded-lg border-x border-b border-gray-700 max-h-60 overflow-y-auto shadow-lg pt-10"
      ></ul>
    </div>
  </div>

  {/* Enlaces (desktop) */}
  <div class="hidden md:flex items-center gap-1 lg:gap-6">
    <a href="/watchlist" class="flex items-center hover:text-red-400 px-1.5 lg:px-0" title="Favoritos">
      <Bookmark class="h-5 w-5 shrink-0" />
      <span class="hidden lg:inline ml-1.5">Favoritos</span>
    </a>
    <a href="/showtimes" class="flex items-center hover:text-red-400 px-1.5 lg:px-0" title="Cartelera">
      <Clock class="h-5 w-5 shrink-0" />
      <span class="hidden lg:inline ml-1.5">Cartelera</span>
    </a>
    <NavDropdown client:load />
  </div>

  {/* Mobile controls: search + hamburger (md: se ocultan ambos) */}
  <div class="flex md:hidden items-center gap-1">
    <button
      id="search-toggle-mobile"
      type="button"
      class="p-2 text-white hover:text-red-400"
      aria-label="Buscar películas"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <Search class="h-6 w-6" />
    </button>
    <button
      id="menu-toggle"
      type="button"
      class="p-2 text-white hover:text-red-400"
      aria-label="Abrir menú"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span id="icon-menu"><Menu class="h-6 w-6" /></span>
      <span id="icon-close" class="hidden"><X class="h-6 w-6" /></span>
    </button>
  </div>
</div>

  {/* Mobile menu - compact modal that sits below the navbar */}
  <div
    id="mobile-menu"
    class="hidden fixed inset-0 z-50 md:hidden"
    style="min-height: 100vh; min-height: 100dvh;"
    role="dialog"
    aria-modal="true"
    aria-labelledby="mobile-menu-title"
  >
    {/* Backdrop covers everything (fills the dvh parent); click closes the modal */}
    <button
      id="mobile-menu-backdrop"
      type="button"
      class="absolute inset-0 bg-black/70 cursor-default"
      aria-label="Cerrar menú"
    ></button>

    {/* Content panel: positioned just below the navbar, auto-sized to dynamic viewport */}
    <div
      class="absolute top-16 left-4 right-4 max-h-[calc(100dvh-5rem)] overflow-y-auto bg-gray-900 text-white rounded-lg shadow-xl border border-gray-800"
    >
      <div class="flex items-center justify-between px-4 py-3 border-b border-gray-800">
        <h2 id="mobile-menu-title" class="text-lg font-semibold">Menú</h2>
        <button
          id="mobile-menu-close"
          type="button"
          class="p-2 text-white hover:text-red-400"
          aria-label="Cerrar menú"
        >
          <X class="h-6 w-6" />
        </button>
      </div>

      <div class="px-4 py-4 flex flex-col gap-4">
        <div class="relative" data-search-wrapper>
          <form class="flex border border-gray-700 rounded-lg overflow-hidden relative z-30" role="search" action={`/${searchCine}/buscar`} method="GET" data-search-form-mobile>
            <input
              type="text"
              name="q"
              value={searchQuery}
              placeholder="Buscar películas..."
              class="flex-1 px-4 py-2 bg-gray-800 text-white focus:outline-none"
              aria-label="Search movies"
              data-search-input
              autocomplete="off"
            />
            {searchQuery && (
              <button
                type="button"
                data-clear-search
                class="bg-gray-800 hover:bg-gray-700 text-gray-400 px-3 flex items-center border-r border-gray-700"
                aria-label="Limpiar búsqueda"
              >
                <X class="h-4 w-4" />
              </button>
            )}
            <button
              type="submit"
              class="bg-gray-800 hover:bg-gray-700 text-gray-500 px-4 py-2 flex items-center justify-center"
              aria-label="Buscar"
            >
              <Search class="h-5 w-5" />
            </button>
          </form>
          <ul
            data-search-suggestions
            class="hidden absolute top-0 left-0 right-0 z-20 bg-gray-800 rounded-lg border-x border-b border-gray-700 max-h-48 overflow-y-auto shadow-lg pt-10"
          ></ul>
        </div>
        <a href="/watchlist" class="flex items-center hover:text-red-400 text-lg">
          <Bookmark class="h-5 w-5 mr-2" />
          Favoritos
        </a>
        <a href="/showtimes" class="flex items-center hover:text-red-400 text-lg">
          <Clock class="h-5 w-5 mr-2" />
          Cartelera
        </a>
        <div>
          <NavDropdown client:load />
        </div>
      </div>
    </div>
  </div>
</nav>

<script>
  document.addEventListener('cineChange', (event) => {
    const cineValue = event.detail.value;
    if (cineValue) {
      window.location.href = `/${cineValue}`;
    }
  });
</script>

<script>
  const toggle = document.getElementById('menu-toggle');
  const searchToggle = document.getElementById('search-toggle-mobile');
  const menu = document.getElementById('mobile-menu');
  const closeBtn = document.getElementById('mobile-menu-close');
  const backdrop = document.getElementById('mobile-menu-backdrop');
  const iconMenuWrap = document.getElementById('icon-menu');
  const iconCloseWrap = document.getElementById('icon-close');

  function openMenu(focusSearch = false) {
    if (!menu || !toggle || !iconMenuWrap || !iconCloseWrap) return;
    menu.classList.remove('hidden');
    document.body.classList.add('overflow-hidden');
    toggle.setAttribute('aria-expanded', 'true');
    toggle.setAttribute('aria-label', 'Cerrar menú');
    if (searchToggle) {
      searchToggle.setAttribute('aria-expanded', 'true');
      searchToggle.setAttribute('aria-label', 'Cerrar menú');
    }
    iconMenuWrap.classList.add('hidden');
    iconCloseWrap.classList.remove('hidden');

    if (focusSearch) {
      // Force synchronous layout reflow so the input is focusable
      // in the same call stack as the click event. This keeps the
      // user-gesture context alive → mobile keyboard appears.
      void menu.offsetHeight;
      const mobileSearch = document.querySelector('#mobile-menu [data-search-input]');
      mobileSearch?.focus();
      mobileSearch?.scrollIntoView({ block: 'center' });
    } else {
      // Hamburger clicked → focus the close button so keyboard users land in the modal
      closeBtn?.focus();
    }
  }

  function closeMenu() {
    if (!menu || !toggle || !iconMenuWrap || !iconCloseWrap) return;
    menu.classList.add('hidden');
    document.body.classList.remove('overflow-hidden');
    toggle.setAttribute('aria-expanded', 'false');
    toggle.setAttribute('aria-label', 'Abrir menú');
    iconMenuWrap.classList.remove('hidden');
    iconCloseWrap.classList.add('hidden');
    if (searchToggle) {
      searchToggle.setAttribute('aria-expanded', 'false');
      searchToggle.setAttribute('aria-label', 'Buscar películas');
    }
    // Return focus to the hamburger trigger
    toggle.focus();
  }

  if (toggle && menu && closeBtn && backdrop) {
    toggle.addEventListener('click', () => {
      const isOpen = !menu.classList.contains('hidden');
      if (isOpen) {
        closeMenu();
      } else {
        openMenu(false);
      }
    });

    if (searchToggle) {
      searchToggle.addEventListener('click', (e) => {
        e.stopPropagation();
        const isOpen = !menu.classList.contains('hidden');
        if (isOpen) {
          closeMenu();
        } else {
          openMenu(true);
        }
      });
    }

    closeBtn.addEventListener('click', closeMenu);
    backdrop.addEventListener('click', closeMenu);

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && !menu.classList.contains('hidden')) {
        closeMenu();
      }
    });
  }
</script>

<script>
  const SEARCH_HISTORY_KEY = "cinemas-henry:search-history";
  const MAX_SUGGESTIONS = 8;

  // ---------------------------------------------------------------------------
  // Helpers
  // ---------------------------------------------------------------------------

  function readHistory() {
    try {
      const raw = localStorage.getItem(SEARCH_HISTORY_KEY);
      if (!raw) return {};
      return JSON.parse(raw);
    } catch { return {}; }
  }

  function saveQuery(cine, query) {
    if (!query.trim()) return;
    const all = readHistory();
    const prev = all[cine] || [];
    const filtered = prev.filter(q => q.toLowerCase() !== query.toLowerCase());
    all[cine] = [query, ...filtered].slice(0, 10);
    try { localStorage.setItem(SEARCH_HISTORY_KEY, JSON.stringify(all)); }
    catch { /* ignore */ }
  }

  function getSuggestions(cine, input) {
    const q = input.toLowerCase().trim();
    const all = readHistory();
    const entries = all[cine] || [];
    if (!q) return entries.slice(0, MAX_SUGGESTIONS);
    return entries.filter(e => e.toLowerCase().includes(q)).slice(0, MAX_SUGGESTIONS);
  }

  // ---------------------------------------------------------------------------
  // Build suggestion items
  // ---------------------------------------------------------------------------

  function renderSuggestions(items, inputEl) {
    const container = inputEl.closest('[data-search-wrapper]')?.querySelector('[data-search-suggestions]');
    if (!container) return;

    if (items.length === 0) {
      container.classList.add('hidden');
      container.innerHTML = '';
      return;
    }

    container.innerHTML = items.map(item =>
      `<li class="px-4 py-2 text-sm text-white hover:bg-gray-700 cursor-pointer flex items-center gap-2 border-b border-gray-700 last:border-0" data-suggestion="${item.replace(/"/g, '&quot;')}">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gray-400 shrink-0"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        <span class="truncate">${item}</span>
      </li>`
    ).join('');
    container.classList.remove('hidden');
  }

  function showSuggestions(inputEl) {
    const cine = inputEl.closest('form')?.getAttribute('action')?.split('/')[1] || '';
    const items = getSuggestions(cine, inputEl.value);
    renderSuggestions(items, inputEl);
  }

  function hideSuggestions(inputEl) {
    const container = inputEl.closest('[data-search-wrapper]')?.querySelector('[data-search-suggestions]');
    if (container) {
      container.classList.add('hidden');
      container.innerHTML = '';
    }
  }

  // ---------------------------------------------------------------------------
  // Persist search on form submit
  // ---------------------------------------------------------------------------

  document.addEventListener('submit', (e) => {
    const form = e.target;
    if (!form.matches('[data-search-form], [data-search-form-mobile]')) return;
    const input = form.querySelector('[data-search-input]');
    if (!input || !input.value.trim()) return;
    const cine = form.getAttribute('action')?.split('/')[1] || '';
    saveQuery(cine, input.value.trim());
  });

  // ---------------------------------------------------------------------------
  // Show/hide suggestions on focus / input
  // ---------------------------------------------------------------------------

  document.addEventListener('focusin', (e) => {
    const input = e.target.closest('[data-search-input]');
    if (!input) return;
    // Small delay so the input has its value before we render
    setTimeout(() => showSuggestions(input), 0);
  });

  document.addEventListener('input', (e) => {
    const input = e.target.closest('[data-search-input]');
    if (!input) return;
    showSuggestions(input);
  });

  // ---------------------------------------------------------------------------
  // Click on suggestion → fill input, hide dropdown, submit
  // ---------------------------------------------------------------------------

  document.addEventListener('mousedown', (e) => {
    const li = e.target.closest('[data-suggestion]');
    if (!li) return;
    const text = li.getAttribute('data-suggestion') || li.textContent.trim();
    const container = li.closest('[data-search-suggestions]');
    if (!container) return;
    const input = container.parentElement.querySelector('[data-search-input]');
    if (!input) return;
    input.value = text;
    hideSuggestions(container);
    // Submit the form
    const form = input.closest('form');
    if (form) form.submit();
  });

  // ---------------------------------------------------------------------------
  // Click outside → hide suggestions
  // ---------------------------------------------------------------------------

  document.addEventListener('click', (e) => {
    const input = e.target.closest('[data-search-input]');
    const suggestion = e.target.closest('[data-search-suggestions]');
    if (input || suggestion) return;
    document.querySelectorAll('[data-search-suggestions]').forEach(el => {
      el.classList.add('hidden');
      el.innerHTML = '';
    });
  });

  // ---------------------------------------------------------------------------
  // Clear search → also hide suggestions
  // ---------------------------------------------------------------------------

  document.addEventListener('click', (e) => {
    const btn = e.target.closest('[data-clear-search]');
    if (!btn) return;
    const form = btn.closest('form');
    if (!form) return;
    const input = form.querySelector('[data-search-input]');
    if (input) {
      input.value = '';
      input.focus();
      setTimeout(() => showSuggestions(input), 0);
    }
  });

  // ---------------------------------------------------------------------------
  // Keyboard navigation (down / up / enter)
  // ---------------------------------------------------------------------------

  document.addEventListener('keydown', (e) => {
    const input = e.target.closest('[data-search-input]');
    if (!input) return;

    const container = input.closest('[data-search-wrapper]')?.querySelector('[data-search-suggestions]');
    if (!container || container.classList.contains('hidden')) return;

    const items = container.querySelectorAll('[data-suggestion]');
    if (items.length === 0) return;

    // Find currently highlighted
    let idx = Array.from(items).findIndex(li => li.classList.contains('bg-gray-700'));

    if (e.key === 'ArrowDown') {
      e.preventDefault();
      items.forEach(li => li.classList.remove('bg-gray-700'));
      idx = Math.min(idx + 1, items.length - 1);
      items[idx].classList.add('bg-gray-700');
      items[idx].scrollIntoView({ block: 'nearest' });
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      items.forEach(li => li.classList.remove('bg-gray-700'));
      idx = idx <= 0 ? items.length - 1 : idx - 1;
      items[idx].classList.add('bg-gray-700');
      items[idx].scrollIntoView({ block: 'nearest' });
    } else if (e.key === 'Enter' && idx >= 0) {
      e.preventDefault();
      input.value = items[idx].getAttribute('data-suggestion') || items[idx].textContent.trim();
      hideSuggestions(container);
      const form = input.closest('form');
      if (form) form.submit();
    } else if (e.key === 'Escape') {
      hideSuggestions(container);
    }
  });
</script>
