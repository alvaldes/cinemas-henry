---
import { Globe } from '@lucide/astro';
---
<footer class="bg-background text-white py-6 container mx-auto flex flex-col items-center justify-between gap-16">
  <div class="border-neutral-800 border-1 w-full "></div>
  <div class="flex items-center justify-between w-full px-4">
    <!-- Logo -->
    <a href="/" aria-label="Logo" class="flex items-center gap-2">
      <img src="/images/LogoH.webp" alt="Logo" class="w-auto h-24" />
    </a>
    <!-- Redes sociales -->
    <div class="border border-gray-800 bg-gray-900/50 p-4 rounded flex flex-col items-center gap-3">
      <span class="text-sm w-full">Sigue a Henry Cinema en:</span>

      <div class="flex items-center gap-3">
        <!-- Página oficial -->
        <a href="https://www.cinemashenry.com.mx/" target="_blank" rel="noopener noreferrer" aria-label="Sitio Oficial" class="hover:text-gray-200 flex items-center gap-1 bg-gradient-to-tr from-red-900 via-red-900 to-red-700 p-2 rounded-full">
          <!-- <Globe class="w-4 h-4" stroke-width="2.5px"/> -->
          <img src="favicon.svg" alt="Logo" class="w-3 h-3" />
          <span class="text-xs font-semibold">Sitio Oficial</span>
        </a>

        <!-- Instagram -->
        <a href="https://www.instagram.com/henrycimenasoficial_" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="hover:text-gray-200 flex items-center gap-1 bg-gradient-to-tr from-yellow-400 via-pink-500 to-purple-600 p-2 rounded-full">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
          </svg>
          <span class="text-xs font-semibold">Instagram</span>
        </a>

        <!-- Facebook -->
        <a href="https://www.facebook.com/HenryCinemasOficial" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="hover:text-gray-200 flex items-center gap-1 bg-[#1877F2] p-2 rounded-full">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4">
            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
          </svg>
          <span class="text-xs font-semibold">Facebook</span>
        </a>
      </div>
    </div>
  </div>
  <!-- Mensaje -->
  <p class="text-sm text-gray-400 font-mono text-center">
    Este sitio fue creado solo con fines educativos para mas información ver:<br />
    <a href="https://www.cinemashenry.com.mx/" target="_blank" class="underline">
      https://www.cinemashenry.com.mx/
    </a>
  </p>
</footer>
