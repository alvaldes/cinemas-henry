---
import type { Movie } from "@/lib/types";
import { Expand } from '@lucide/astro';
import { formatDuration } from '@/lib/utils';
import IconFavoriteButton from '@/components/IconFavoriteButton';
import { Image } from 'astro:assets';

const { videos } = Astro.props as { videos: Movie[] };
const cine = Astro.url.pathname.split('/')[1];
---

<section class="my-8 mx-auto flex flex-col w-full bg-background text-white">
  <!-- Main Trailer Carousel -->
  <div id="trailer-scroll" class="max-w-dvw w-full overflow-hidden snap-x snap-mandatory scroll-smooth no-scrollbar relative">
    <div class="flex">
      {videos.map((video: Movie, index) => (
        <div class="snap-start shrink-0 w-full relative" id={`video-item-${index}`}> {/* id for debugging */}
          <div class="aspect-video w-full overflow-hidden rounded-lg">
            <lite-youtube
              videoid={video.trailer.split("/" ).pop()}
              autoload={index === 0}
              autopause
              posterquality="maxresdefault"
              class="w-full h-full"
            />
          </div>
          <div class="absolute bottom-0 left-0 h-auto bg-gradient-to-t from-background from-10% via-background/80 via-30% to-transparent to-40% p-0 w-full max-w-dvw">
            <a href={
              `/${cine}/${encodeURIComponent(video.id)}`
            } class="inline-block cursor-pointer relative group overflow-hidden rounded">
              <Image
                src={video.img_primary}
                alt={`Poster de ${video.title}`}
                width={200}
                height={300}
                loading={index === 0 ? "eager" : "lazy"}
                fetchpriority={index === 0 ? "high" : "auto"}
                class="rounded object-cover w-auto h-24 sm:h-48 transition-transform duration-300 group-hover:scale-105"
              />
              <div class="absolute inset-0 bg-black/60 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center rounded">
                <Expand class="h-8 w-8 text-white" />
              </div>
            </a>
            <div class="absolute top-0 left-0 w-7 sm:w-8 h-auto">
              <IconFavoriteButton
                cine={cine}
                movieId={video.id}
                client:load
              />
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- Up Next as Synchronized Thumbnails -->
  <div class="w-full max-w-dvw h-auto mx-0 mt-1">
    <h3 class="text-yellow-500 font-semibold mb-4">Próximos Estrenos</h3>
    <div id="thumbnail-list" class="flex overflow-x-auto snap-x snap-mandatory scroll-smooth no-scrollbar gap-4">
      {videos.map((video: Movie, index) => (
        <div class="snap-start shrink-0 opacity-40 hover:opacity-100 transition-opacity cursor-pointer" data-index={index}>
          <div class="flex space-x-2 cursor-pointer hover:bg-white/10 p-2 rounded">
            <Image
              src={video.img_primary}
              alt={`Miniatura de ${video.title}`}
              width={48}
              height={72}
              class="object-cover w-12 h-18 rounded flex-shrink-0"
            />
            <div class="flex flex-col items-start">
              <p class="text-xs">▶ {formatDuration(video.duration)}</p>
              <p class="font-bold text-sm capitalize">{video.title}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
lite-youtube {
  --lite-youtube-frame-shadow-visible: no;
}
.no-scrollbar::-webkit-scrollbar {
  display: none;
}
.no-scrollbar {
  -ms-overflow-style: none;
  scrollbar-width: none;
}
</style>

<script>
import '@justinribeiro/lite-youtube';

const trailerScroll = document.getElementById('trailer-scroll');
const thumbsContainer = document.getElementById('thumbnail-list');
let activeIndex = 0;

function setActive(idx) {
  const thumbs = document.querySelectorAll('[data-index]');
  thumbs.forEach((thumb, i) => {
    thumb.classList.toggle('opacity-40', i !== idx);
    thumb.classList.toggle('opacity-100', i === idx);
  });
}

function scrollToVideo(idx) {
  if (!trailerScroll) return;
  const width = trailerScroll.clientWidth;
  if (width === 0) return;
  trailerScroll.scrollTo({
    left: idx * width,
    behavior: 'smooth',
  });
  setActive(idx);
}

// Event delegation for thumbnails
thumbsContainer?.addEventListener('click', (e) => {
  const thumb = e.target.closest('[data-index]');
  if (!thumb) return;
  const idx = parseInt(thumb.dataset.index, 10);
  if (!isNaN(idx)) scrollToVideo(idx);
});

if (trailerScroll) {
  trailerScroll.addEventListener('scroll', () => {
    const width = trailerScroll.clientWidth;
    if (width === 0) return;
    const idx = Math.round(trailerScroll.scrollLeft / width);
    if (idx !== activeIndex) {
      activeIndex = idx;
      setActive(idx);
    }
  });
  setActive(0);
}
</script>
