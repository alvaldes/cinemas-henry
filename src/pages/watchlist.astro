---
import MainLayout from '@/layouts/main.astro';
import FavoritesList from '@/components/FavoritesList';
---

<MainLayout content={{ title: 'Mis Favoritos' }}>
	<section class="container mx-auto py-6 text-white">
		<div class="mb-1 md:mb-3">
			<h1 class="text-2xl md:text-3xl font-bold flex items-center">
				<span class="text-yellow-400 mr-1 text-3xl md:text-4xl">|</span> Mis Favoritos
			</h1>
			<p class="text-sm text-gray-400 mt-1">
				Las películas que marques se guardan en este navegador.
			</p>
		</div>
		<FavoritesList client:load />
	</section>
</MainLayout>
