---
import { defaultCines, DEFAULT_CINE_VALUE } from "@/lib/constants";

// Server-side redirect at root that reads the selectedCine cookie.
// Falls back to the default if the cookie is missing or invalid.
const selectedCine = Astro.cookies.get("selectedCine")?.value;
const isValid = selectedCine && defaultCines.some((c) => c.value === selectedCine);
const cine = isValid ? selectedCine : DEFAULT_CINE_VALUE;

return Astro.redirect(`/${cine}`);
---
